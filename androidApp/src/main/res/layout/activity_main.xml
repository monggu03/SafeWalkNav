<?xml version="1.0" encoding="utf-8"?>
<!--
시각장애인 풀스크린 UI — PR-UX1 (사용자 흐름 재설계)

상태별 화면 구성:
  1. BEFORE (idle)
     · 빈 화면 (시각장애인은 화면 안 봐도 OK)
     · TTS: "내비게이션을 실행하시려면 화면을 꾹 눌러주세요"
     · 트리거: 화면 전체 long press 2초 → STT
     · DEBUG 빌드 한정: 하단에 작은 디버그 정보 박스 (GPS / TalkBack / 마지막 검색)

  2. RESULTS (검색 결과)
     · resultsContainer 가 화면 전체로 visible
     · 코드에서 동적으로 1~5개 큰 버튼 추가 (위→아래로 균등 분배)
     · 각 버튼은 contentDescription 풍부 → TalkBack 한 번 탭 = 읽기, 더블탭 = 선택

  3. NAVIGATING (이동 중)
     · cameraPreviewContainer 가 화면 전체로 차지 (PR-3 가 PreviewView 추가)
     · BEFORE 영역 / 결과 영역 모두 hide
     · 시각장애인은 화면 안 보고 음성/진동/비콘 안내만 사용

  4. ARRIVED (도착)
     · 짧게 도착 안내 (3초) 후 자동으로 BEFORE 로 복귀

설계 근거:
  · 화면 전체가 단일 long press 영역 — 위치 의존성 제거
  · 검색 결과는 균등 분배 버튼 — TalkBack 표준 인터랙션 (탭→듣기, 더블탭→선택)
  · 흔들기 폐기 — 가방/주머니 실수 트리거 위험 (향후 NAVIGATING 음성 명령용으로 재도입 가능)
  · 카메라 풀스크린 — 시연자/보호자가 "작동 중" 즉시 인지

색상 톤:
  · 배경: #000000 (검정 — OLED 친화 + 저시력자 대비)
  · 메인 텍스트: #FFFFFF (흰)
  · 강조: #FFD700 (노랑)
  · 도착: #00CC66 (초록)
  · 디버그: #666666 (어두운 회색 — 사용자에 거의 안 보이지만 시연 시 충분)
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:clickable="true"
    android:focusable="true"
    android:contentDescription="화면을 2초간 길게 눌러 음성으로 목적지를 입력하세요">

    <!-- ========== 카메라 프리뷰 영역 ==========
         NAVIGATING 상태에서만 visibility=VISIBLE.
         PR-3 (김수영) 가 이 안에 PreviewView + 인식 결과 오버레이 추가. -->
    <FrameLayout
        android:id="@+id/cameraPreviewContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:visibility="gone"
        android:importantForAccessibility="no" />

    <!-- ========== BEFORE 화면 컨테이너 ==========
         IDLE / LISTENING / SEARCHING 상태에서 visible.
         시각장애인은 안 봐도 됨 — TTS 만으로 흐름 안내.
         시연/저시력자용 큰 텍스트 한 줄만 (DEBUG 빌드만 표시). -->
    <LinearLayout
        android:id="@+id/beforeContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/tvBeforeHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="28sp"
            android:textColor="#FFD700"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="24dp"
            android:visibility="gone"
            tools:text="화면을 2초간 길게 눌러주세요"
            tools:visibility="visible" />
    </LinearLayout>

    <!-- ========== 검색 결과 컨테이너 ==========
         RESULTS 상태에서 visible. 코드에서 LinearLayout 안에 1~5개 버튼 동적 추가.
         각 버튼은 layout_weight=1 로 균등 분배 → TalkBack 으로 탐색 용이.
         더블탭(TalkBack 표준)으로 선택. -->
    <LinearLayout
        android:id="@+id/resultsContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="8dp"
        android:visibility="gone"
        tools:visibility="gone" />

    <!-- ========== ARRIVED 화면 컨테이너 ==========
         도착 후 3초간 표시되고 자동으로 BEFORE 로 복귀. -->
    <LinearLayout
        android:id="@+id/arrivedContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓ 도착"
            android:textSize="48sp"
            android:textStyle="bold"
            android:textColor="#00CC66"
            android:gravity="center"
            android:contentDescription="목적지에 도착했습니다" />

        <TextView
            android:id="@+id/tvArrivedName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="28sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:layout_marginTop="16dp"
            tools:text="스타벅스 강남점에 도착했습니다" />
    </LinearLayout>

    <!-- ========== DEBUG 디버그 정보 박스 ==========
         BuildConfig.DEBUG 일 때만 visibility=VISIBLE (코드에서 제어).
         Release 빌드에서는 진짜 빈 화면. -->
    <LinearLayout
        android:id="@+id/debugContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="bottom"
        android:padding="8dp"
        android:background="#1A1A1A"
        android:visibility="gone"
        android:importantForAccessibility="no"
        tools:visibility="visible">

        <TextView
            android:id="@+id/tvDebugStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="11sp"
            android:textColor="#666666"
            android:fontFamily="monospace"
            android:importantForAccessibility="no"
            tools:text="STATE=IDLE | GPS=OK | TalkBack=OFF | last=충무로역" />

        <TextView
            android:id="@+id/tvDebugGuidance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="11sp"
            android:textColor="#666666"
            android:fontFamily="monospace"
            android:layout_marginTop="2dp"
            android:importantForAccessibility="no"
            tools:text="guidance=목적지까지 200미터" />
    </LinearLayout>

</FrameLayout>
